      "cell_type": "markdown",
      "source": [
        "kfold es una tecnica de validacion cruzada\n"
      ],
      "metadata": {
        "id": "WOjJi_JJQhg2"
      }
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "id": "53d5c835"
      },
      "outputs": [],
      "source": [
        "from sklearn.preprocessing import OneHotEncoder\n",
        "from sklearn.model_selection import KFold\n",
        "import category_encoders as ce\n",
        "\n",
        "df_onehot = pd.get_dummies(df, columns=onehot_encode_cols, drop_first=True)\n",
        "\n",
        "kf = KFold(n_splits=5, shuffle=True, random_state=42)\n",
        "df_target = df_onehot.copy()\n",
        "\n",
        "for col in target_encode_cols:\n",
        "    encoder = ce.TargetEncoder(cols=[col])\n",
        "    df_target[col] = encoder.fit_transform(df_target[col], df_target['SalePrice'])\n",
        "\n",
        "df_encoded = df_target.copy()"
      ]
    },
