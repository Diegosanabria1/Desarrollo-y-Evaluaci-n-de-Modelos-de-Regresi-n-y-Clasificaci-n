        },
        "id": "f5060875",
        "outputId": "30d10021-dc8e-4032-b18f-ccd56f82e8e1"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Categorical columns for target encoding (more than 20 unique values):\n",
            "['Neighborhood', 'Condition1', 'Condition2', 'HouseStyle', 'RoofStyle', 'RoofMatl', 'Exterior1st', 'Exterior2nd', 'Foundation', 'BsmtFinType1', 'BsmtFinType2', 'Heating', 'Functional', 'GarageType', 'SaleType', 'SaleCondition']\n",
            "\n",
            "Categorical columns for one-hot encoding (20 or fewer unique values):\n",
            "['MSZoning', 'Street', 'Alley', 'LotShape', 'LandContour', 'Utilities', 'LotConfig', 'LandSlope', 'BldgType', 'MasVnrType', 'ExterQual', 'ExterCond', 'BsmtQual', 'BsmtCond', 'BsmtExposure', 'HeatingQC', 'CentralAir', 'Electrical', 'KitchenQual', 'FireplaceQu', 'GarageFinish', 'GarageQual', 'GarageCond', 'PavedDrive', 'PoolQC', 'Fence', 'MiscFeature']\n"
          ]
        }
      ],
      "source": [
        "string_cols = df.select_dtypes(include='object').columns\n",
        "if 'SalePrice' in string_cols:\n",
        "    string_cols = string_cols.drop('SalePrice')\n",
        "\n",
        "target_encode_cols = []\n",
        "onehot_encode_cols = []\n",
        "\n",
        "for col in string_cols:\n",
        "    if df[col].nunique() > 5:\n",
        "        target_encode_cols.append(col)\n",
        "    else:\n",
        "        onehot_encode_cols.append(col)\n",
        "\n",
        "\n",
        "print(\"Categorical columns for target encoding (more than 20 unique values):\")\n",
        "print(target_encode_cols)\n",
        "\n",
        "print(\"\\nCategorical columns for one-hot encoding (20 or fewer unique values):\")\n",
        "print(onehot_encode_cols)"
      ]
