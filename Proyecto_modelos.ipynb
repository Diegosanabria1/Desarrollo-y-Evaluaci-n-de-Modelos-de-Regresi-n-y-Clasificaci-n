        "correlation_with_saleprice = df_encoded_reduced.corr()['SalePrice'].abs().sort_values(ascending=False)\n",
        "\n",
        "low_corr_threshold = 0.3\n",
        "\n",
        "low_corr_vars = correlation_with_saleprice[correlation_with_saleprice < low_corr_threshold].index.tolist()\n",
        "if 'SalePrice' in low_corr_vars:\n",
        "    low_corr_vars.remove('SalePrice')\n",
        "\n",
        "\n",
        "print(f\"Variables con correlación absoluta menor a {low_corr_threshold} con SalePrice:\")\n",
        "for var in low_corr_vars:\n",
        "    print(f\"- {var}: {correlation_with_saleprice[var]:.2f}\")\n",
        "\n",
        "df_encoded_reduced_further = df_encoded_reduced.drop(columns=low_corr_vars)\n",
        "\n",
        "print(\"\\nDimensiones del DataFrame después de eliminar variables con baja correlación:\", df_encoded_reduced_further.shape)"
