      "source": [
        "y_pred_sgd_binary = sgd_logistic_model.predict(X_test_scaled)\n",
        "\n",
        "accuracy_sgd_binary = accuracy_score(y_test_binary, y_pred_sgd_binary)\n",
        "conf_matrix_sgd_binary = confusion_matrix(y_test_binary, y_pred_sgd_binary)\n",
        "class_report_sgd_binary = classification_report(y_test_binary, y_pred_sgd_binary)\n",
        "\n",
        "print(f\"Metricas para Regresion Logistica SGD\")\n",
        "print(f\"Accuracy: {accuracy_sgd_binary:.2f}\")\n",
        "print(\"\\nConfusion Matrix:\")\n",
        "print(conf_matrix_sgd_binary)\n",
        "print(\"\\nClassification Report:\")\n",
        "print(class_report_sgd_binary)"
